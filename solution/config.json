{
  "provider": "openai",
  "model": "mistral-small-latest",
  "model_price_tier": "standard",
  "max_steps": 6,
  "loop_guard": true,
  "temperature": 0.1,
  "context_size": 4,
  "verbose_system": false,
  "timeout_ms": 0,
  "max_completion_tokens": 400,
  "retry": {"enabled": true, "max_attempts": 3, "backoff_ms": 200},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 5,
  "tool_error_rate": 0.0,
  "catalog_override": {},
  "route_rules": [],
  "planner": false,
  "verify": false,
  "self_consistency": 1,
  "tool_budget": 4
}
